# ── Server ─────────────────────────────────────────────────────
PORT=3001

# ── Database ────────────────────────────────────────────────────
# For local dev: leave blank to use ambassador.db in project root
# For Railway: set to the volume mount path, e.g. /data/ambassador.db
DB_PATH=

# ── Auth ────────────────────────────────────────────────────────
# Change this to a long random string in production!
JWT_SECRET=change-me-to-a-secure-random-string

# ── Team Logins ─────────────────────────────────────────────────
# Optional: override default demo credentials (JSON array)
# Format: [{"username":"admin","password":"secret","name":"Admin User"}]
# If not set, defaults are: admin/lovepop2024 and team/ambassador123
TEAM_USERS=

# ── File Uploads ─────────────────────────────────────────────────
# Upload directory is derived from DB_PATH if set, otherwise public/uploads/
# No config needed unless you want a custom path

# ── Railway Production Notes ─────────────────────────────────────
# 1. Add a Railway Volume at /data and set DB_PATH=/data/ambassador.db
# 2. Set JWT_SECRET to a strong random value
# 3. Set TEAM_USERS to your team's credentials
# 4. Node 22+ is required (set in railway.toml)
